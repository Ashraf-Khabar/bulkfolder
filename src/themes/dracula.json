  "CTkScrollbar": {
    "corner_radius": 1000,
    "border_width": 0,
    "fg_color": ["#44475a", "#44475a"],
    "button_color": ["#6272a4", "#6272a4"],
    "button_hover_color": ["#7082b6", "#7082b6"]
