{
  "CTk": {
    "fg_color": ["#282a36", "#282a36"]
  },

  "CTkFont": {
    "family": "Segoe UI",
    "size": 13,
    "weight": "normal"
  },

  "CTkFrame": {
    "corner_radius": 12,
    "border_width": 1,
    "fg_color": ["#282a36", "#282a36"],
    "top_fg_color": ["#282a36", "#282a36"],
    "border_color": ["#44475a", "#44475a"]
  },

  "CTkLabel": {
    "corner_radius": 0,
    "fg_color": "transparent",
    "text_color": ["#f8f8f2", "#f8f8f2"]
  },

  "CTkButton": {
    "corner_radius": 10,
    "border_width": 0,
    "fg_color": ["#6272a4", "#6272a4"],
    "hover_color": ["#7082b6", "#7082b6"],
    "border_color": ["#44475a", "#44475a"],
    "text_color": ["#f8f8f2", "#f8f8f2"],
    "text_color_disabled": ["#7a7a7a", "#7a7a7a"]
  },

  "CTkEntry": {
    "corner_radius": 10,
    "border_width": 1,
    "fg_color": ["#1e1f29", "#1e1f29"],
    "border_color": ["#44475a", "#44475a"],
    "text_color": ["#f8f8f2", "#f8f8f2"],
    "placeholder_text_color": ["#9aa0a6", "#9aa0a6"]
  },

  "CTkTextbox": {
    "corner_radius": 10,
    "border_width": 1,
    "fg_color": ["#1e1f29", "#1e1f29"],
    "border_color": ["#44475a", "#44475a"],
    "text_color": ["#f8f8f2", "#f8f8f2"],
    "scrollbar_button_color": ["#44475a", "#44475a"],
    "scrollbar_button_hover_color": ["#6272a4", "#6272a4"]
