  "CTkProgressBar": {
    "corner_radius": 1000,
    "border_width": 0,
    "fg_color": ["#44475a", "#44475a"],
    "progress_color": ["#bd93f9", "#bd93f9"],
    "border_color": ["#44475a", "#44475a"]
